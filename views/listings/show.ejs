<% layout("./layout/boilerplate.ejs") %>
<body>
  <div class="row mt-3">
    <div class="col-8 offset-2">
      <h3>Listing Details :</h3>
    </div>  
    <div class="card col-6 offset-2" >
        <img src="<%= clickedListing.image %>" class="card-img-top show-img mt-3" alt="listing_image">
        <div class="card-body">
          <p class="card-text">
            <b><%= clickedListing.title %></b><br>
            <%= clickedListing.description %> <br>
            &#8377;<%= clickedListing.price.toLocaleString("en-IN")%> <br>
            <%= clickedListing.location %> <br>
            <%= clickedListing.country %> <br>
          </p>
        </div>
    </div>
      <!-- <ul>
          <li><%= clickedListing.title %></li>
          <li><%= clickedListing.description %></li>
          <li>&#8377;<%= clickedListing.price.toLocaleString("en-IN")%></li>
          <li><%= clickedListing.location %></li>
          <li></li>
      </ul> -->
      <br>
      <div class="btns">
        <a href="/listings/<%= clickedListing._id %>/edit" class="btn btn-dark col-1 offset-2 edit-btn" >Edit</a>
        <form action="/listings/<%= clickedListing._id %>?_method=DELETE" method="post">
          <button class="btn btn-dark offset-4 " >Delete</button>
        </form> 
      </div>  
  </div>     
</body>
