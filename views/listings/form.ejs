<% layout("./layout/boilerplate.ejs") %>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-2" >
            <h3>Create a New Listing</h3>
    
            <form action="/listings" method="post">
                <div class="mb-3 mt-3">
                    <label class="form-label" for="title">Title</label>
                    <input id="title" class="form-control" type="text" name="listing[title]" placeholder="Enter title" >
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>   
                    <textarea name="listing[description]" class="form-control" id="description"  placeholder="Enter description"></textarea>
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Image Link</label>
                    <input type="text" id="image" class="form-control" name="listing[image]" placeholder="Enter image URL">
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4"> 
                        <label for="price" class="form-label">Price</label>
                        <input type="number" id="price" class="form-control" name="listing[price]" placeholder="Enter price">
                    </div>
                    <div class="mb-3 col-md-8 ">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" id="country" class="form-control" name="listing[country]" placeholder="Enter country">
                    </div>
                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" id="location" class="form-control" name="listing[location]" placeholder="Enter Location">
                </div>
                <button class="btn btn-dark add-btn mb-5 mt-5">Add</button>
            </form>
        </div>
    </div>
</body>
